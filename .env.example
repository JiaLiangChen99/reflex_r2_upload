# R2 直传（运行 Demo 与集成测试前必填）
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=https://your-cdn.example.com

# 可选
# REFLEX_R2_ROUTE_PREFIX=/_reflex_r2_upload
# REFLEX_R2_PRESIGN_EXPIRES=600
# REFLEX_R2_GET_EXPIRES=3600   # 私有桶 presigned GET 默认有效期（秒）
# REFLEX_R2_UPLOAD_SECRET=       # 上传 token 签名密钥；未设置时从 R2 凭证自动派生
# REFLEX_R2_UPLOAD_TOKEN_TTL=7200
# REFLEX_R2_REQUIRE_UPLOAD_TOKEN=1  # 设为 0 可关闭 presign/complete 鉴权（仅开发）
# REFLEX_R2_REQUIRE_BRIDGE_SIGNATURE=1  # 设为 0 可关闭 bridge 签名校验（仅开发）
# REFLEX_R2_MAX_UPLOAD_BYTES=104857600  # 单文件上传上限（字节），默认 100 MiB；0 表示不限制
# REFLEX_R2_RATE_LIMIT_REQUESTS=60        # 每 IP 窗口内允许的 API 请求数，0 关闭限流
# REFLEX_R2_RATE_LIMIT_WINDOW=60          # 限流窗口（秒）
# REFLEX_R2_VERBOSE_CONFIG=0            # 设为 1 时 /config 返回 missingEnv 等诊断字段

# 公开桶：配置 CDN 域名，bridge publicUrl 才有值
# 私有桶：留空 R2_PUBLIC_BASE_URL，读访问用 r2.signed_read_url()
